{
  "name": "shapefile-toolkit",
  "version": "1.0.0",
  "description": "Professional Windows GIS Data Batch Processing Toolbox - The most beautiful SHP batch tool",
  "main": "main.js",
  "author": "Shapefile Toolkit",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder build --win portable --x64",
    "build:dir": "electron-builder build --win portable --x64 --dir"
  },
  "build": {
    "appId": "com.shapefile-toolkit.app",
    "productName": "Shapefile Toolkit",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "lib/**/*",
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "${productName}-${version}-win-x64-portable.${ext}",
      "icon": "src/assets/icon.ico"
    },
    "asar": true,
    "asarUnpack": [
      "lib/**",
      "node_modules/shapefile/**",
      "node_modules/@turf/**"
    ]
  },
  "dependencies": {
    "@turf/turf": "^6.5.0",
    "csv-parse": "^5.5.2",
    "csv-stringify": "^6.4.4",
    "jszip": "^3.10.1",
    "proj4": "^2.9.0",
    "shapefile": "^0.6.6",
    "wellknown": "^0.5.0"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^26.15.3"
  },
  "allowScripts": {
    "electron@28.1.0": true
  }
}
